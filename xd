<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <title>LUTEC | Tienda de Robótica</title>
    <script src="https://accounts.google.com/gsi/client" async defer></script>
    <style>
        :root { --teal: #008184; --dark: #1e1e1e; --glow: #00ff41; --bg: #f4f7f6; }
        body { margin: 0; font-family: 'Courier New', monospace; background: var(--bg); color: #333; }
        
        header { background: var(--dark); padding: 15px 5%; display: flex; justify-content: space-between; align-items: center; color: var(--glow); border-bottom: 3px solid var(--teal); position: sticky; top: 0; z-index: 1000; }
        .logo { font-weight: bold; font-size: 22px; letter-spacing: 2px; }

        .container { padding: 20px 5%; max-width: 1200px; margin: 0 auto; }
        
        /* Mini IA de Búsqueda */
        .ia-box { background: #2d2d2d; color: var(--glow); padding: 15px; border-radius: 10px; margin-bottom: 20px; border: 1px solid var(--teal); }
        #ia-input { background: #1e1e1e; border: 1px solid var(--glow); color: var(--glow); padding: 8px; width: 80%; }

        /* Carrito y Formulario de Envío */
        .checkout-section { background: white; border: 2px solid var(--dark); padding: 20px; border-radius: 10px; margin-bottom: 25px; box-shadow: 5px 5px 0px var(--teal); }
        .grid-forms { display: grid; grid-template-columns: 1fr 1fr; gap: 15px; margin-top: 15px; }

        /* Catálogo */
        .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(250px, 1fr)); gap: 20px; }
        .p-card { background: white; padding: 15px; border-radius: 8px; border: 1px solid #ddd; transition: 0.3s; }
        .p-card:hover { transform: scale(1.02); border-color: var(--teal); }
        .p-img { width: 100%; height: 150px; object-fit: cover; border-radius: 5px; }

        /* Estilo Botones */
        .btn { background: var(--teal); color: white; border: none; padding: 10px; cursor: pointer; font-family: inherit; font-weight: bold; width: 100%; margin-top: 10px; }
        .btn:hover { background: var(--dark); color: var(--glow); }
        
        #admin-panel { display: none; background: #333; color: white; padding: 20px; border-radius: 10px; margin-bottom: 20px; }
        .info-footer { font-size: 11px; margin-top: 40px; padding: 20px; background: #eee; border-radius: 5px; }
    </style>
</head>
<body>

<header>
    <div class="logo">> LUTEC_PRO_STORE</div>
    <div id="user-status">MODO: INVITADO</div>
</header>

<div class="container">
    <!-- MINI IA DE BÚSQUEDA -->
    <div class="ia-box">
        <span>[ MINI_IA ]:</span> 
        <input type="text" id="ia-input" placeholder="¿Qué buscas? (Ej: 'quiero un arduino' o 'motores')" onkeyup="miniIA()">
        <p id="ia-msg" style="font-size: 12px; margin-top: 5px;">Esperando comandos...</p>
    </div>

    <!-- PANEL ADMIN (LUCAS) -->
    <div id="admin-panel">
        <h3>// MODO_ADMIN_LUCAS</h3>
        <input type="text" id="n-name" placeholder="Nombre">
        <input type="number" id="n-price" placeholder="Precio (Solo números)">
        <input type="text" id="n-img" placeholder="Link de imagen">
        <button class="btn" onclick="addItem()">CARGAR AL SISTEMA</button>
    </div>

    <!-- ACCESO -->
    <div id="login-zone" style="text-align: center; margin-bottom: 20px;">
        <div id="g_id_onload" data-client_id="689849272801-7ecrvsb7beggv6e9qsrs11oouvrji08t.apps.googleusercontent.com" data-callback="handleSignIn"></div>
        <div class="g_id_signin" data-type="standard"></div>
        <button onclick="accessAs('Admin')" style="margin-top:10px; cursor:pointer;">Acceso Directo (Admin)</button>
    </div>

    <!-- CARRITO Y DATOS DE ENVÍO -->
    <div class="checkout-section">
        <h3>[ MI_PEDIDO ]</h3>
        <div id="cart-list">El carrito está vacío.</div>
        <div class="grid-forms">
            <div>
                <label>Dirección de Envío:</label>
                <input type="text" id="ship-address" placeholder="Calle, Ciudad, Chile">
            </div>
            <div>
                <label>Método de Pago:</label>
                <select id="pay-method" style="width:100%; padding:8px;">
                    <option>Transferencia Bancaria</option>
                    <option>WebPay (Pesos Chilenos)</option>
                </select>
            </div>
        </div>
        <p><strong>TOTAL: $<span id="total-val">0</span> CLP</strong></p>
        <button class="btn" style="background:#28a745;" onclick="processOrder()">CONFIRMAR COMPRA</button>
    </div>

    <div class="product-grid" id="catalog"></div>

    <!-- POLÍTICAS REALES -->
    <div class="info-footer">
        <strong>POLÍTICA DE DEVOLUCIÓN:</strong> Tienes 30 días para devolver componentes si no han sido soldados. <br>
        <strong>ENVÍOS:</strong> Despacho a todo Chile vía Starken o Chilexpress en 48 horas. <br>
        <strong>SOPORTE:</strong> Contacto directo para proyectos con Arduino y ESP32.
    </div>
</div>

<script>
    let cart = [];
    let products = [
        { id: 1, name: "Arduino Nano ESP32", price: 12500, img: "https://www.arduino.cc/en/uploads/Main/ArduinoNanoESP32-Product.jpg" },
        { id: 2, name: "Servo Motor SG90", price: 3500, img: "https://m.media-amazon.com/images/I/51A2-NScJkL._AC_SL1000_.jpg" },
        { id: 3, name: "Raspberry Pi 3B", price: 45000, img: "https://m.media-amazon.com/images/I/91zXv7A9y0L._AC_SL1500_.jpg" }
    ];

    function handleSignIn(resp) {
        const user = JSON.parse(atob(resp.credential.split('.')[1]));
        if(user.email === "lutecpro20@gmail.com") accessAs('Admin');
    }

    function accessAs(role) {
        document.getElementById('user-status').innerText = "SISTEMA: " + role.toUpperCase();
        if(role === 'Admin') document.getElementById('admin-panel').style.display = 'block';
        document.getElementById('login-zone').style.display = 'none';
        render();
    }

    function render(filterList = products) {
        const catalog = document.getElementById('catalog');
        catalog.innerHTML = "";
        filterList.forEach(p => {
            catalog.innerHTML += `
                <div class="p-card">
                    <img src="${p.img}" class="p-img">
                    <h4>${p.name}</h4>
                    <p style="color:var(--teal); font-weight:bold;">$${p.price.toLocaleString()} CLP</p>
                    <button class="btn" onclick="addToCart(${p.id})">AÑADIR AL CARRO</button>
                </div>
            `;
        });
    }

    function miniIA() {
        const query = document.getElementById('ia-input').value.toLowerCase();
        const msg = document.getElementById('ia-msg');
        if(!query) { render(); msg.innerText = "Esperando comandos..."; return; }

        const found = products.filter(p => p.name.toLowerCase().includes(query));
        render(found);

        if(found.length > 0) {
            msg.innerText = `IA: He encontrado ${found.length} coincidencias para ti.`;
        } else {
            msg.innerText = "IA: No encuentro eso en los servidores de Lutec.";
        }
    }

    function addToCart(id) {
        cart.push(products.find(p => p.id === id));
        updateCart();
    }

    function updateCart() {
        const list = document.getElementById('cart-list');
        const total = document.getElementById('total-val');
        if(cart.length === 0) { list.innerText = "El carrito está vacío."; total.innerText = "0"; return; }
        
        list.innerHTML = cart.map((item, idx) => `
            <div style="display:flex; justify-content:space-between; font-size:12px; border-bottom:1px solid #eee;">
                <span>> ${item.name}</span>
                <span>$${item.price.toLocaleString()} <button onclick="remove(${idx})" style="color:red;border:none;background:none;cursor:pointer;">[X]</button></span>
            </div>
        `).join('');
        
        const sum = cart.reduce((s, i) => s + i.price, 0);
        total.innerText = sum.toLocaleString();
    }

    function remove(idx) { cart.splice(idx, 1); updateCart(); }

    function processOrder() {
        const addr = document.getElementById('ship-address').value;
        if(!addr || cart.length === 0) return alert("ERROR: El carrito está vacío o falta la dirección.");
        alert(`ORDEN PROCESADA\nEnviaremos a: ${addr}\nTotal: $${document.getElementById('total-val').innerText} CLP\n¡Gracias por comprar en Lutec, Lucas!`);
        cart = []; updateCart();
    }

    function addItem() {
        const n = document.getElementById('n-name').value;
        const p = parseInt(document.getElementById('n-price').value);
        const i = document.getElementById('n-img').value;
        if(n && p) {
            products.push({ id: Date.now(), name: n, price: p, img: i });
            render();
        }
    }

    render();
</script>
</body>
</html>
